{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  },
  "permission": {
    "*": "ask",
    "read": "allow",
    "grep *": "allow",
    "glob *": "allow",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "gh pr view *": "allow",
      "xcodebuild *": "allow",
      "xcrun *": "allow",
      "swift test*": "allow",
      "ls *": "allow",
      "rg *": "allow",
      "rm *": "deny",
      "sudo *": "deny"
    },
    "edit": "ask",
    "webfetch": "ask"
  }
}